# База даних PostgreSQL
POSTGRES_DB=testify_db
POSTGRES_USER=testify_user
POSTGRES_PASSWORD=your_password_here

# Порт для бази даних на хост-машині (щоб уникнути конфлікту зі встановленим Postgres)
DB_LOCAL_PORT=5433

# Секретний ключ для підпису JWT токенів (згенеруйте довгий випадковий рядок для продакшену)
JWT_SECRET=your_super_secret_jwt_key_here